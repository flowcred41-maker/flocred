                <div className="w-10 h-10 rounded-xl flex items-center justify-center mb-3 transition-all" style={{background:'rgba(201,168,76,.1)'}}>
                  <svg className="w-5 h-5" style={{color:'#C9A84C'}} fill="none" stroke="currentColor" viewBox="0 0 24 24">{p.icon}</svg>
