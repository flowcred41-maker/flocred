'use client';
import { useState, useEffect, useRef } from 'react';
import Link from 'next/link';
import { saveLead, saveNRI } from '@/lib/supabase';
import Navbar from '@/components/Navbar';
import Footer from '@/components/Footer';
import Toast from '@/components/Toast';

const WORKER = process.env.NEXT_PUBLIC_WORKER_URL;

export default function HomeClient() {
  const [toast, setToast] = useState<{msg:string;type:'success'|'error'}|null>(null);
  const [billing, setBilling] = useState<'monthly'|'quarterly'|'yearly'>('monthly');
  const [calcAmount, setCalcAmount] = useState(1000000);
  const [calcRate, setCalcRate] = useState(10.5);
  const [calcTenure, setCalcTenure] = useState(60);
  const [liveRates, setLiveRates] = useState({ pl:'10.49%', hl:'8.4%', cl:'8.65%', bl:'10.75%', ts:'' });
  const [exRates, setExRates] = useState({ usd:'₹83.5', gbp:'₹105.7', aed:'₹22.7' });
  const [loginModal, setLoginModal] = useState(false);
  const [loginTab, setLoginTab] = useState<'customer'|'employee'>('customer');
  const [otpStep, setOtpStep] = useState(1);
  const [loginPhone, setLoginPhone] = useState('');
  const [otp, setOtp] = useState('');
  const [nriSuccess, setNriSuccess] = useState(false);
  const [quickLoading, setQuickLoading] = useState(false);
  const [faqOpen, setFaqOpen] = useState<number|null>(null);
  const revealRefs = useRef<HTMLElement[]>([]);
  const teamOnline = (() => { try { const n = new Date(new Date().toLocaleString('en-US',{timeZone:'Asia/Kolkata'})); return n.getDay()>=1&&n.getDay()<=6&&n.getHours()>=9&&n.getHours()<19; } catch { return false; } })();

  const showToast = (msg: string, type: 'success'|'error' = 'success') => {
    setToast({msg,type}); setTimeout(() => setToast(null), 3500);
  };

  // EMI calc
  const r = calcRate/100/12, n = calcTenure;
  const emi = Math.round(calcAmount * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1));
  const totalPay = emi * n;
  const totalInt = totalPay - calcAmount;
  const fmt = (v: number) => v>=10000000 ? `₹${(v/10000000).toFixed(2)}Cr` : v>=100000 ? `₹${(v/100000).toFixed(2)}L` : `₹${Math.round(v).toLocaleString('en-IN')}`;

  // Reveal on scroll
  useEffect(() => {
    const obs = new IntersectionObserver(entries => entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); }), { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    return () => obs.disconnect();
  }, []);

  // Live rates from Supabase
  useEffect(() => {
    import('@/lib/supabase').then(({ getLiveRates }) => {
      getLiveRates().then(data => {
        if (!data.length) return;
        const rates: Record<string,number> = {};
        data.forEach((row: {product:string;min_rate:number}) => { if(!rates[row.product]||row.min_rate<rates[row.product]) rates[row.product]=row.min_rate; });
        setLiveRates({
          pl: rates.personal_loan ? rates.personal_loan+'%' : '10.49%',
          hl: rates.home_loan ? rates.home_loan+'%' : '8.4%',
          cl: rates.car_loan ? rates.car_loan+'%' : '8.65%',
          bl: rates.business_loan ? rates.business_loan+'%' : '10.75%',
          ts: new Date().toISOString().split('T')[0],
        });
      });
    });
  }, []);

  // Exchange rates
  useEffect(() => {
    const fetch_ = () => fetch('https://open.er-api.com/v6/latest/USD').then(r=>r.json()).then(d => {
      if(d?.rates?.INR){ const inr=d.rates.INR; setExRates({ usd:`₹${inr.toFixed(2)}`, gbp:`₹${(inr/(d.rates.GBP||0.79)).toFixed(2)}`, aed:`₹${(inr/(d.rates.AED||3.67)).toFixed(2)}` }); }
    }).catch(()=>{});
    fetch_(); const t = setInterval(fetch_, 30*60*1000); return () => clearInterval(t);
  }, []);

  const PLAN_PRICES = { basic:{monthly:299,quarterly:749,yearly:2499}, pro:{monthly:1299,quarterly:3249,yearly:10999}, enterprise:{monthly:4999,quarterly:12499,yearly:42999} };

  async function handleQuickCheck(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault(); setQuickLoading(true);
    const f = e.currentTarget;
    const fd = new FormData(f);
    const pan = (fd.get('pan') as string||'').toUpperCase();
    let panName = fd.get('name') as string;
    if (pan && /^[A-Z]{5}[0-9]{4}[A-Z]$/.test(pan)) {
      showToast('Verifying PAN with government database...','success');
      try {
        const res = await fetch(`${WORKER}/api/verify-pan`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pan})});
        const data = await res.json();
        if(data?.data?.full_name) { panName=data.data.full_name; showToast(`PAN Verified: ${panName} ✓`,'success'); }
      } catch {}
    }
    await saveLead({ name:panName, phone:fd.get('phone') as string, loan_type:fd.get('loan_type') as string, amount:fd.get('income') as string, source:'website_quick_check', notes:`Employment: ${fd.get('employment')} | PAN: ${pan||'Not provided'} | Monthly Income: ₹${fd.get('income')}` });
    showToast('Eligibility check submitted! We will call you in 30 minutes.','success');
    f.reset(); setQuickLoading(false);
  }

  async function handleContact(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault();
    const f = e.currentTarget; const fd = new FormData(f);
    await saveLead({ name:fd.get('name') as string, phone:fd.get('phone') as string, email:fd.get('email') as string||null, loan_type:fd.get('loan_type') as string, amount:fd.get('amount') as string||null, source:'website_contact', notes:fd.get('message') as string||null });
    showToast('Application submitted! Our team will contact you within 30 minutes.','success'); f.reset();
  }

  async function handleNRI(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault();
    const f = e.currentTarget; const fd = new FormData(f);
    await saveNRI({ name:fd.get('name') as string, email:fd.get('email') as string, phone:fd.get('phone') as string, country:fd.get('country') as string, product:fd.get('product') as string||undefined });
    setNriSuccess(true); showToast('NRI waitlist registration successful!','success');
  }

  async function sendOTP() {
    if(!loginPhone||loginPhone.length!==10){showToast('Enter valid 10-digit mobile number','error');return;}
    try { await fetch(`${WORKER}/api/send-otp`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mobile:loginPhone})}); }
    catch {}
    setOtpStep(2); showToast(`OTP sent to +91-${loginPhone}`,'success');
  }

  async function verifyOTP() {
    try {
      const res = await fetch(`${WORKER}/api/verify-otp`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mobile:loginPhone,otp})});
      const data = await res.json();
      if(data.type==='success'){
        sessionStorage.setItem('fc_customer',JSON.stringify({phone:loginPhone,loggedIn:true,loginTime:new Date().toISOString()}));
        showToast('Login successful! Redirecting...','success'); setLoginModal(false);
        setTimeout(()=>window.location.href='/dashboard',800);
      } else { showToast('Invalid OTP. Try again.','error'); }
    } catch { showToast('Verification failed','error'); }
  }

  return (
    <>
      <Navbar onLoginClick={()=>setLoginModal(true)} />
      {toast && <Toast msg={toast.msg} type={toast.type}/>}

      {/* ── LOGIN MODAL ── */}
      {loginModal && (
        <div className="modal-overlay active" onClick={e=>{if(e.target===e.currentTarget)setLoginModal(false)}}>
          <div className="modal-box">
            <button onClick={()=>setLoginModal(false)} style={{position:'absolute',top:12,right:12,background:'none',border:'none',color:'#6B6459',fontSize:20,cursor:'pointer',width:32,height:32,display:'flex',alignItems:'center',justifyContent:'center',borderRadius:8}}>✕</button>
            <div className="text-base font-bold mb-3" style={{fontFamily:'Fraunces,serif',color:'#F5F0E8'}}>Welcome to FLOCRED</div>
            <p className="text-xs mb-4" style={{color:'rgba(245,240,232,.4)'}}>Login to check your eligibility and track applications</p>
            {/* Tabs */}
            <div className="flex mb-4" style={{background:'rgba(255,255,255,.03)',borderRadius:10,padding:3,border:'1px solid rgba(255,255,255,.07)'}}>
              {(['customer','employee'] as const).map(tab=>(
                <button key={tab} onClick={()=>setLoginTab(tab)} className="flex-1 py-2 text-xs font-semibold rounded-lg transition-all capitalize"
                  style={loginTab===tab?{background:'#C9A84C',color:'#0D0D0D'}:{color:'rgba(245,240,232,.4)',background:'none'}}>
                  {tab}
                </button>
              ))}
            </div>
            {loginTab==='customer' ? (
              <>
                {otpStep===1 ? (
                  <div className="space-y-3">
                    <input value={loginPhone} onChange={e=>setLoginPhone(e.target.value.replace(/\D/g,'').slice(0,10))} placeholder="Mobile Number" className="input-dark" maxLength={10}/>
                    <button onClick={sendOTP} className="btn-gold w-full py-3 rounded-xl text-sm justify-center">Send OTP via WhatsApp</button>
                  </div>
                ) : (
                  <div className="space-y-3">
                    <p className="text-xs" style={{color:'rgba(245,240,232,.5)'}}>OTP sent to +91-{loginPhone}</p>
                    <input value={otp} onChange={e=>setOtp(e.target.value.replace(/\D/g,'').slice(0,6))} placeholder="6-digit OTP" className="input-dark font-mono" maxLength={6}/>
                    <button onClick={verifyOTP} className="btn-gold w-full py-3 rounded-xl text-sm justify-center">Verify & Login</button>
                    <button onClick={()=>setOtpStep(1)} className="text-xs w-full text-center" style={{color:'rgba(245,240,232,.3)',background:'none',border:'none',cursor:'pointer'}}>Resend OTP</button>
                  </div>
                )}
              </>
            ) : (
              <div className="space-y-3">
                <input id="emp-id" placeholder="Employee ID or Email" className="input-dark"/>
                <input id="emp-pass" type="password" placeholder="Password" className="input-dark"/>
                <button onClick={()=>{const id=(document.getElementById('emp-id') as HTMLInputElement)?.value;const p=(document.getElementById('emp-pass') as HTMLInputElement)?.value;if(id&&p)window.location.href='/admin';else showToast('Enter Employee ID and Password','error');}} className="btn-gold w-full py-3 rounded-xl text-sm justify-center">Login to CRM</button>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ══════════════════════════════════════════════════════════ */}
      {/* HERO */}
      {/* ══════════════════════════════════════════════════════════ */}
      <section className="min-h-[90vh] flex items-center pt-20 pb-10 relative overflow-hidden section-dark">
        {/* Background effects */}
        <div className="absolute" style={{width:'500px',height:'500px',background:'radial-gradient(circle,rgba(201,168,76,.05),transparent 70%)',top:'10%',left:'5%',borderRadius:'50%',filter:'blur(130px)',pointerEvents:'none'}}/>
        <div className="absolute" style={{width:'400px',height:'400px',background:'radial-gradient(circle,rgba(201,168,76,.04),transparent 70%)',bottom:'10%',right:'5%',borderRadius:'50%',filter:'blur(110px)',pointerEvents:'none'}}/>
        <div className="absolute inset-0 opacity-[.015]" style={{backgroundImage:'linear-gradient(rgba(201,168,76,.3) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.3) 1px,transparent 1px)',backgroundSize:'60px 60px'}}/>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
          <div className="grid lg:grid-cols-2 gap-10 items-center">
            <div>
              <div className="fade-up inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs mb-6 glass-light" style={{color:'rgba(245,240,232,.5)'}}>
                <span className="w-1.5 h-1.5 rounded-full" style={{background:'#C9A84C',animation:'pulse-glow 2s infinite'}}/>
                DPIIT Recognised &nbsp;·&nbsp; 50+ Bank Partners &nbsp;·&nbsp; Startup India Registered
              </div>
              <h1 className="fade-up-d1 text-4xl sm:text-5xl lg:text-[56px] font-bold leading-[1.1] tracking-tight mb-5" style={{color:'#F5F0E8'}}>
                Stop Getting<br/><span className="gradient-text">Rejected.</span><br/>Know First.
              </h1>
              <p className="fade-up-d2 text-base sm:text-lg mb-8 max-w-md leading-relaxed" style={{color:'rgba(245,240,232,.5)'}}>
                Most people apply and then find out they don&apos;t qualify. We flip that. Enter your details, get your real number, then apply only where you&apos;ll be approved — <span style={{color:'rgba(245,240,232,.85)',fontWeight:500}}>in under 2 minutes</span>.
              </p>
              <div className="fade-up-d3 flex flex-wrap gap-3 mb-10">
                <a href="#eligibility" className="btn-gold px-7 py-3.5 rounded-2xl text-sm">
                  See How Much I Qualify For
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="#cibil" className="btn-ghost px-6 py-3.5 rounded-2xl text-sm">Check My CIBIL Score</a>
              </div>
              <div className="fade-up-d3 flex gap-8">
                {[['50+','Banks We Check'],['2 min',"That's all it takes"],['Free','Zero cost to start']].map(([v,l])=>(
                  <div key={l}>
                    <div className="text-2xl font-bold stat-num" style={{color:'#F5F0E8'}}>{v}</div>
                    <div className="text-[11px] mt-0.5" style={{color:'rgba(245,240,232,.35)'}}>{l}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Quick eligibility card */}
            <div className="fade-up-d2">
              <div className="glass rounded-3xl p-6 sm:p-8 glow-gold max-w-md mx-auto lg:ml-auto">
                <div className="text-center mb-6">
                  <div className="text-lg font-bold" style={{fontFamily:'Fraunces,serif',color:'#F5F0E8'}}>What&apos;s your real loan limit?</div>
                  <div className="text-xs mt-1" style={{color:'rgba(245,240,232,.35)'}}>60 seconds. No documents. No credit score hit.</div>
                </div>
                <form onSubmit={handleQuickCheck} className="space-y-3">
                  <input name="name" required placeholder="Full Name" className="input-dark"/>
                  <input name="phone" required placeholder="Mobile Number" className="input-dark" maxLength={10} pattern="[0-9]{10}"/>
                  <select name="employment" required className="input-dark" style={{appearance:'none'}}>
                    <option value="">Employment Type</option>
                    <option value="salaried">Salaried</option>
                    <option value="self_employed">Self Employed / Business</option>
                    <option value="professional">Professional (Doctor/CA/Lawyer)</option>
                  </select>
                  <input name="income" required type="number" placeholder="Monthly Income (₹)" className="input-dark" min="10000"/>
                  <select name="loan_type" required className="input-dark" style={{appearance:'none'}}>
                    <option value="">Loan Type Needed</option>
                    <option value="personal_loan">Personal Loan</option>
                    <option value="business_loan">Business Loan</option>
                    <option value="home_loan">Home Loan</option>
                    <option value="lap">Loan Against Property</option>
                    <option value="car_loan">Car Loan</option>
                    <option value="working_capital">Working Capital</option>
                  </select>
                  <input name="pan" placeholder="PAN Number (for CIBIL check)" className="input-dark font-mono uppercase" maxLength={10} pattern="[A-Z]{5}[0-9]{4}[A-Z]"/>
                  <button type="submit" disabled={quickLoading} className="btn-gold w-full py-3.5 rounded-2xl text-sm justify-center">
                    {quickLoading ? (
                      <><svg className="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"/><path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Checking...</>
                    ) : <>Show Me My Loan Limit <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></>}
                  </button>
                </form>
                <div className="text-center mt-3 text-[10px]" style={{color:'rgba(245,240,232,.25)'}}>We don&apos;t sell your data. Period.</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ── TRUST STRIP ── */}
      <section className="py-5 border-y reveal" style={{background:'#0D0D0D',borderColor:'rgba(201,168,76,.1)'}}>
        <div className="max-w-7xl mx-auto px-4">
          <div className="flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-[11px]" style={{color:'rgba(245,240,232,.3)'}}>
            {['RBI Compliant Platform','50+ Bank Partners','256-bit SSL Encrypted','CIN: U67100DL2022PTC400764','Startup India Registered'].map(item=>(
              <span key={item} className="flex items-center gap-1.5">
                <svg className="w-3.5 h-3.5" fill="currentColor" style={{color:'#C9A84C'}} viewBox="0 0 20 20"><path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"/></svg>
                {item}
              </span>
            ))}
          </div>
        </div>
      </section>

      {/* ── HOW IT WORKS ── */}
      <section id="eligibility" className="section-light reveal" style={{position:'relative',overflow:'hidden'}}>
        <div className="blob blob-gold" style={{width:'400px',height:'400px',top:'-100px',right:'-80px',opacity:.07}}/>
        <div className="gold-ring" style={{width:'180px',height:'180px',top:'40px',right:'60px'}}/>
        <div className="gold-ring" style={{width:'100px',height:'100px',bottom:'80px',left:'40px'}}/>
        <div className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div className="py-16 text-center">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>The Process</span>
            <h2 className="text-3xl sm:text-4xl font-bold mt-2" style={{color:'#0D0D0D'}}>No branch visits. No guesswork.</h2>
            <p className="text-sm mt-2 max-w-lg mx-auto" style={{color:'#6B6459'}}>Most loan rejections happen because people apply blind. We fix that.</p>
          </div>
          <div style={{border:'1px solid rgba(0,0,0,.08)',borderRadius:24,overflow:'hidden'}}>
            {[
              {n:'1',label:'Step one',title:'Tell us the basics',desc:"Name, income, what you need. No bank statements, no salary slips, no Aadhaar scan. Just 60 seconds.",m1:'60s',l1:'Total time',m2:'0',l2:'Documents needed',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>},
              {n:'2',label:'Step two',title:'We run the numbers',desc:'Your CIBIL score, what banks allow on your income, your existing EMI load — we calculate the exact amount a bank will approve.',m1:'50+',l1:'Banks checked',m2:'Live',l2:'CIBIL data',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a1 1 0 001-1v-5a1 1 0 00-1-1H4a1 1 0 00-1 1v5a1 1 0 001 1zM7 7h.01M5 7a2 2 0 012-2h10a2 2 0 012 2v2H5V7z"/>},
              {n:'3',label:'Step three',title:"Apply where you'll actually get approved",desc:"You see your eligible amount, which banks will say yes, and at what rate. No surprises at the bank counter.",m1:'',l1:'',m2:'',l2:'',cta:true,icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>},
            ].map((step,i)=>(
              <div key={step.n} className={`step-row${i===1?' flip':''}`} style={{borderBottom:i<2?'1px solid rgba(0,0,0,.06)':'none'}}>
                <div className="step-text">
                  <div style={{display:'inline-flex',alignItems:'center',gap:8,marginBottom:16}}>
                    <div style={{width:28,height:28,borderRadius:8,background:'rgba(201,168,76,.12)',border:'1px solid rgba(201,168,76,.2)',display:'flex',alignItems:'center',justifyContent:'center',fontFamily:'Fraunces,serif',fontSize:13,fontWeight:700,color:'#C9A84C'}}>{step.n}</div>
                    <span style={{fontSize:10,fontWeight:600,letterSpacing:'.12em',textTransform:'uppercase',color:'#C9A84C'}}>{step.label}</span>
                  </div>
                  <h3 style={{fontFamily:'Fraunces,serif',fontSize:'clamp(22px,3vw,30px)',fontWeight:700,color:'#0D0D0D',lineHeight:1.2,marginBottom:14}}>{step.title}</h3>
                  <p style={{fontSize:14,lineHeight:1.75,color:'#6B6459',maxWidth:380}}>{step.desc}</p>
                  {step.m1 && (
                    <div style={{display:'flex',gap:20,marginTop:24}}>
                      <div><div className="stat-num" style={{fontSize:22,fontWeight:700,color:'#0D0D0D'}}>{step.m1}</div><div style={{fontSize:10,color:'#6B6459',marginTop:2}}>{step.l1}</div></div>
                      <div style={{width:1,background:'rgba(0,0,0,.08)'}}/>
                      <div><div className="stat-num" style={{fontSize:22,fontWeight:700,color:'#0D0D0D'}}>{step.m2}</div><div style={{fontSize:10,color:'#6B6459',marginTop:2}}>{step.l2}</div></div>
                    </div>
                  )}
                  {step.cta && (
                    <div style={{marginTop:28}}>
                      <a href="#eligibility" className="btn-gold px-6 py-3 rounded-xl text-sm">
                        Start Now — it&apos;s free
                        <svg style={{width:14,height:14}} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                      </a>
                    </div>
                  )}
                </div>
                <div className="step-visual">
                  <div className="step-icon-wrap">
                    <svg style={{width:36,height:36,color:'#C9A84C'}} fill="none" stroke="currentColor" viewBox="0 0 24 24">{step.icon}</svg>
                  </div>
                  <div className="step-num-large">{step.n}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── CIBIL PLANS ── */}
      <section id="cibil" className="py-16 section-dark reveal">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="text-center mb-12">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Your Credit Score</span>
            <h2 className="text-3xl sm:text-4xl font-bold mt-2" style={{color:'#F5F0E8'}}>A low CIBIL score costs you <span className="gradient-text">lakhs in higher interest.</span></h2>
            <p className="text-sm mt-2 max-w-lg mx-auto" style={{color:'rgba(245,240,232,.4)'}}>Get your official report, find out exactly where you stand, and if your score needs work — we&apos;ll fix that too.</p>
          </div>
          {/* Billing toggle */}
          <div className="flex items-center justify-center gap-3 mb-8">
            {(['monthly','quarterly','yearly'] as const).map(c=>(
              <button key={c} onClick={()=>setBilling(c)} className="px-4 py-1.5 rounded-lg text-xs font-medium relative capitalize transition-all"
                style={billing===c?{background:'rgba(201,168,76,.15)',color:'#C9A84C',border:'1px solid rgba(201,168,76,.2)'}:{color:'rgba(245,240,232,.4)',background:'none',border:'none'}}>
                {c}{c==='yearly'&&<span className="absolute -top-2 -right-6 text-[9px] px-1.5 py-0.5 rounded-full font-semibold" style={{background:'#C9A84C',color:'#0D0D0D'}}>-30%</span>}
              </button>
            ))}
          </div>
          {/* Plan cards */}
          <div className="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
            {([ { key:'basic', name:'Basic', desc:'Checking your own score', features:['3 eligibility checks/month','CIBIL Score + PDF Report','PAN Verification','Loan eligibility across all types','EMI Calculator'], missing:['CIBIL Boost (add-on)'], featured:false },
               { key:'pro', name:'Pro', desc:'Serious borrowers & loan agents', features:['8 eligibility checks/month','CIBIL + Experian Reports','PAN + Aadhaar Verification','Multi-lender matching','PDF Credit Reports','CIBIL Boost included','WhatsApp notifications'], missing:[], featured:true },
               { key:'enterprise', name:'Enterprise', desc:'Companies & high-volume agents', features:['50 eligibility checks/month','All 4 Credit Bureaus','Full KYC Suite (PAN+Aadhaar+GST)','Team dashboard (5 users)','White-label reports','Dedicated account manager','API Access'], missing:[], featured:false }
            ] as const).map(plan=>(
              <div key={plan.key} className="glass rounded-3xl p-6 relative" style={{borderColor:plan.featured?'rgba(201,168,76,.3)':'rgba(255,255,255,.07)',boxShadow:plan.featured?'0 0 50px rgba(201,168,76,.08)':'none'}}>
                {plan.featured&&<div className="absolute -top-3 left-1/2 -translate-x-1/2 text-[10px] font-semibold px-4 py-1 rounded-full" style={{background:'#C9A84C',color:'#0D0D0D'}}>Most Popular</div>}
                <div className="text-xs font-semibold tracking-wider uppercase mb-1" style={{color:'#C9A84C'}}>{plan.name}</div>
                <div className="text-xs mb-4" style={{color:'rgba(245,240,232,.3)'}}>{plan.desc}</div>
                <div className="flex items-baseline gap-1 mb-1">
                  <span className="text-3xl font-bold stat-num" style={{color:'#F5F0E8'}}>₹{(PLAN_PRICES[plan.key][billing]).toLocaleString('en-IN')}</span>
                  <span className="text-xs" style={{color:'rgba(245,240,232,.3)'}}>{billing==='monthly'?'/month':billing==='quarterly'?'/quarter':'/year'}</span>
                </div>
                <ul className="space-y-2.5 mb-6 text-xs" style={{color:'rgba(245,240,232,.5)'}}>
                  {plan.features.map(f=>(
                    <li key={f} className="flex items-start gap-2">
                      <svg className="w-3.5 h-3.5 flex-shrink-0 mt-0.5" fill="currentColor" style={{color:'#C9A84C'}} viewBox="0 0 20 20"><path fillRule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clipRule="evenodd"/></svg>
                      {f}
                    </li>
                  ))}
                  {plan.missing.map(f=>(
                    <li key={f} className="flex items-start gap-2" style={{color:'rgba(245,240,232,.2)'}}>
                      <svg className="w-3.5 h-3.5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clipRule="evenodd"/></svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <Link href="/cibil-score" className={`w-full py-3 rounded-xl text-sm flex items-center justify-center ${plan.featured?'btn-gold':'btn-ghost'}`}>
                  Get {plan.name} Plan
                </Link>
              </div>
            ))}
          </div>
          {/* CIBIL Boost banner */}
          <div className="max-w-3xl mx-auto mt-8 glass rounded-2xl p-5 flex flex-col sm:flex-row items-center gap-4" style={{borderColor:'rgba(201,168,76,.2)'}}>
            <div className="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style={{background:'rgba(201,168,76,.1)'}}>
              <svg className="w-6 h-6" style={{color:'#C9A84C'}} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div className="text-center sm:text-left">
              <div className="text-sm font-semibold" style={{color:'#F5F0E8'}}>Score below 700? Don&apos;t apply anywhere yet.</div>
              <div className="text-xs mt-0.5" style={{color:'rgba(245,240,232,.4)'}}>Every rejected application drops your score further. Our CIBIL Boost program lifts it 50–200 points in 3–6 months before you apply. Free with Pro and Enterprise.</div>
            </div>
            <Link href="/cibil-score#boost" className="btn-gold px-5 py-2 rounded-xl text-xs flex-shrink-0">Learn More</Link>
          </div>
        </div>
      </section>

      {/* ── PRODUCTS ── */}
      <section id="products" className="py-16 section-warm reveal">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
