                <div className="text-[11px] mt-1" style={{color:'#6B6459'}}>From {p.rate} p.a. | {p.max}</div>
                <div className="text-[10px] mt-2 font-semibold" style={{color:'#C9A84C'}}>Apply Now →</div>
