      {/* ── LIVE RATES ── */}
      <section className="py-10 section-light reveal">
        <div className="max-w-4xl mx-auto px-4">
          <div className="rounded-2xl p-6 relative overflow-hidden" style={{background:'#fff',border:'1px solid rgba(201,168,76,.15)'}}>
            <div className="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[9px] font-semibold" style={{background:'rgba(201,168,76,.12)',color:'#C9A84C'}}>LIVE RATES</div>
            <div className="text-center mb-4">
              <div className="text-lg font-bold" style={{fontFamily:'Fraunces,serif',color:'#0D0D0D'}}>Today&apos;s rates from our partner banks</div>
