      </section>

      {/* ── CORPORATE + ABOUT ── */}
      <section className="py-16 section-dark reveal">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="text-center mb-10">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>For employers</span>
            <h2 className="text-3xl font-bold mt-2" style={{color:'#F5F0E8'}}>Your employees are distracted by money stress. We fix that.</h2>
            <p className="text-sm mt-2" style={{color:'rgba(245,240,232,.4)'}}>Financial stress is the #1 reason employees underperform. Give them access to real loans — at real rates — with 3–6 months before the first EMI hits.</p>
          </div>
          <div className="grid md:grid-cols-4 gap-4 mb-8">
            {[['One place for everything','Personal loans, home loans, car loans — one team, one number'],['No EMI for 3–6 months',"Your employees start paying only after they've settled in"],['We negotiate the rate',"They don't need to shop around — we already did it across 50+ banks"],['One person, start to finish','Not a chatbot. A real relationship manager who picks up the phone']].map(([title,sub])=>(
              <div key={title} className="glass rounded-xl p-4 text-center">
                <div className="text-sm font-semibold mb-1" style={{color:'#F5F0E8'}}>{title}</div>
                <div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>{sub}</div>
              </div>
            ))}
          </div>
          <div className="grid md:grid-cols-2 gap-6">
            <div className="glass rounded-2xl p-6">
              <div className="text-xs font-semibold tracking-wider uppercase mb-3" style={{color:'#C9A84C'}}>About FLOCRED</div>
              <p className="text-xs leading-relaxed mb-4" style={{color:'rgba(245,240,232,.4)'}}>We started FLOCRED because getting a loan in India was unnecessarily hard. Too much paperwork, too many rejections, no transparency on why. We built the platform we wished existed — one that tells you the truth before you apply.</p>
              <div className="grid grid-cols-2 gap-3">
                {[['2022','Founded'],['Pan India','Operations'],['RBI Compliant','All processes'],['256-bit SSL','Bank-grade security']].map(([v,l])=>(
                  <div key={l} className="rounded-lg p-2.5 text-center" style={{background:'rgba(255,255,255,.03)'}}>
                    <div className="text-sm font-bold stat-num" style={{color:'#F5F0E8'}}>{v}</div>
                    <div className="text-[9px]" style={{color:'rgba(245,240,232,.3)'}}>{l}</div>
                  </div>
                ))}
              </div>
            </div>
            <div className="rounded-2xl p-6" style={{background:'rgba(220,38,38,.05)',border:'1px solid rgba(220,38,38,.2)'}}>
              <div className="flex items-center gap-2 mb-3">
                <svg className="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clipRule="evenodd"/></svg>
                <div className="text-sm font-bold text-red-400">Beware of Fraudsters</div>
              </div>
              <p className="text-xs leading-relaxed mb-3" style={{color:'rgba(245,240,232,.4)'}}>FLOCRED never asks for upfront payments, OTPs, or bank passwords via phone/SMS. If someone contacts you claiming to be from FLOCRED and asks for money or personal banking details, do not share.</p>
              <p className="text-xs" style={{color:'rgba(245,240,232,.4)'}}>Report immediately to <span style={{color:'rgba(245,240,232,.65)'}}>support@flocred.com</span> or call <span style={{color:'rgba(245,240,232,.65)'}}>+91-9319369315</span></p>
            </div>
          </div>
        </div>
      </section>

      {/* ── NRI SECTION ── */}
      <section id="nri" className="py-16 section-warm reveal">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Coming Soon</span>
              <h2 className="text-3xl font-bold mt-2 mb-3" style={{color:'#0D0D0D'}}>NRI Loans — <span className="gradient-text">without the paperwork chase</span></h2>
              <p className="text-sm mb-4 leading-relaxed" style={{color:'#6B6459'}}>You&apos;ve been sending money home for years. Buying property or investing in India shouldn&apos;t require you to fly back. We&apos;re building the platform that handles everything from wherever you are.</p>
              <div className="space-y-2 mb-6">
                {[{code:'HL',name:'NRI Home Loans',sub:'Buy property in India from anywhere. No flying back required. From 8.5% p.a.'},{code:'LAP',name:'NRI Loan Against Property',sub:'Your Indian property is sitting on equity. Put it to work. Up to 70% LTV.'},{code:'IF',name:'NRI Investment Financing',sub:'Commercial property and FD-backed loans — managed remotely, start to finish.'}].map(item=>(
                  <div key={item.code} className="rounded-xl p-3 flex items-center gap-3" style={{background:'#fff',border:'1px solid rgba(0,0,0,.07)'}}>
                    <div className="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0" style={{background:'rgba(201,168,76,.1)',color:'#C9A84C'}}>{item.code}</div>
                    <div>
                      <div className="text-xs font-medium" style={{color:'#0D0D0D'}}>{item.name}</div>
                      <div className="text-[10px]" style={{color:'#6B6459'}}>{item.sub}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div className="flex flex-wrap gap-2 text-[10px]" style={{color:'#6B6459'}}>
                {['UAE','UK','USA','Canada','Singapore'].map(c=>(
                  <span key={c} className="px-2 py-1 rounded-lg" style={{background:'#fff',border:'1px solid rgba(0,0,0,.08)'}}>{c}</span>
                ))}
              </div>
            </div>
            <div>
              <div className="rounded-3xl p-6" style={{background:'#fff',border:'1px solid rgba(201,168,76,.15)'}}>
                {!nriSuccess ? (
                  <>
                    <div className="text-sm font-bold mb-1" style={{fontFamily:'Fraunces,serif',color:'#0D0D0D'}}>Get notified when NRI Loans launch</div>
                    <div className="text-[10px] mb-4" style={{color:'#6B6459'}}>We&apos;ll reach out personally — not with a mass email blast.</div>
                    <form onSubmit={handleNRI} className="space-y-3">
                      <input name="name" required placeholder="Full Name *" className="input-light"/>
                      <div className="grid grid-cols-2 gap-3">
                        <input name="email" type="email" required placeholder="Email *" className="input-light"/>
                        <input name="phone" type="tel" required placeholder="Phone *" className="input-light"/>
                      </div>
                      <select name="country" required className="input-light" style={{appearance:'none'}}>
                        <option value="">Country of Residence *</option>
                        {['UAE','United Kingdom','United States','Canada','Singapore','Australia','Saudi Arabia','Qatar','Other'].map(c=><option key={c} value={c}>{c}</option>)}
                      </select>
                      <select name="product" className="input-light" style={{appearance:'none'}}>
                        <option value="">Interested In</option>
                        <option value="nri_home_loan">NRI Home Loan</option>
                        <option value="nri_lap">NRI Loan Against Property</option>
                        <option value="nri_investment">NRI Investment Financing</option>
                        <option value="multiple">Multiple Products</option>
                      </select>
                      <button type="submit" className="btn-gold w-full py-3 rounded-xl text-sm font-semibold justify-center">Join NRI Waitlist</button>
                    </form>
                  </>
                ) : (
                  <div className="text-center py-6">
                    <div className="text-2xl mb-2" style={{color:'#C9A84C'}}>✓</div>
                    <div className="text-sm font-bold" style={{color:'#0D0D0D'}}>You&apos;re on the list!</div>
                    <div className="text-[10px] mt-1" style={{color:'#6B6459'}}>We&apos;ll notify you when NRI Loans go live.</div>
                  </div>
                )}
              </div>
              {/* Exchange rates */}
              <div className="rounded-xl p-4 mt-3" style={{background:'#fff',border:'1px solid rgba(0,0,0,.07)'}}>
                <div className="text-[10px] mb-2" style={{color:'#6B6459'}}>Live Exchange Rates</div>
                <div className="grid grid-cols-3 gap-2 text-[10px]">
                  {[['USD',exRates.usd],['GBP',exRates.gbp],['AED',exRates.aed]].map(([cur,val])=>(
                    <div key={cur} className="text-center">
                      <div style={{color:'#6B6459'}}>{cur}</div>
                      <div className="font-mono font-semibold" style={{color:'#0D0D0D'}}>{val}</div>
                    </div>
                  ))}
                </div>
                <div className="text-[9px] text-center mt-2" style={{color:'rgba(0,0,0,.2)'}}>Auto-updated every 30 min</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ── EMI CALCULATOR ── */}
      <section id="calculator" className="py-16 section-dark reveal">
        <div className="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="text-center mb-10">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Plan Your Loan</span>
            <h2 className="text-3xl sm:text-4xl font-bold mt-2" style={{color:'#F5F0E8'}}>Know your EMI before you commit.</h2>
            <p className="text-sm mt-2" style={{color:'rgba(245,240,232,.4)'}}>Drag the sliders. See what you&apos;re actually signing up for.</p>
          </div>
          <div className="glass rounded-3xl p-6 sm:p-8 max-w-3xl mx-auto" style={{borderColor:'rgba(201,168,76,.1)'}}>
            <div className="grid md:grid-cols-2 gap-8">
              <div className="space-y-6">
                {[
                  { label:'Loan Amount', val:`₹${calcAmount.toLocaleString('en-IN')}`, min:50000, max:1000000000, step:50000, value:calcAmount, onChange:(v:number)=>setCalcAmount(v), display:'₹50K','end':'₹100 Cr' },
                  { label:'Interest Rate (p.a.)', val:`${calcRate.toFixed(2)}%`, min:6, max:30, step:0.25, value:calcRate, onChange:(v:number)=>setCalcRate(v), display:'6%','end':'30%' },
                  { label:'Tenure', val:`${calcTenure} months${calcTenure>=12?' ('+Math.round(calcTenure/12)+' yrs)':''}`, min:6, max:360, step:6, value:calcTenure, onChange:(v:number)=>setCalcTenure(v), display:'6 mo','end':'30 yrs' },
                ].map(s=>(
                  <div key={s.label}>
                    <div className="flex justify-between text-xs mb-2">
                      <span style={{color:'rgba(245,240,232,.4)'}}>{s.label}</span>
                      <span className="font-mono font-medium" style={{color:'#F5F0E8'}}>{s.val}</span>
                    </div>
                    <input type="range" min={s.min} max={s.max} value={s.value} step={s.step} onChange={e=>s.onChange(parseFloat(e.target.value))} className="w-full" style={{accentColor:'#C9A84C'}}/>
                    <div className="flex justify-between text-[10px] mt-1" style={{color:'rgba(245,240,232,.2)'}}>
                      <span>{s.display}</span><span>{s['end']}</span>
                    </div>
                  </div>
                ))}
              </div>
              <div className="flex flex-col items-center justify-center text-center">
                <div className="text-xs mb-1" style={{color:'rgba(245,240,232,.3)'}}>Your Monthly EMI</div>
                <div className="text-4xl font-bold font-mono mb-4 stat-num" style={{color:'#F5F0E8'}}>₹{emi.toLocaleString('en-IN')}</div>
                <div className="grid grid-cols-2 gap-4 w-full">
                  <div className="glass-light rounded-xl p-3 text-center">
                    <div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>Total Interest</div>
                    <div className="text-sm font-semibold font-mono" style={{color:'#C9A84C'}}>{fmt(totalInt)}</div>
                  </div>
                  <div className="glass-light rounded-xl p-3 text-center">
                    <div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>Total Payment</div>
                    <div className="text-sm font-semibold font-mono" style={{color:'#F5F0E8'}}>{fmt(totalPay)}</div>
                  </div>
                </div>
                <a href="#eligibility" className="btn-gold px-6 py-2.5 rounded-xl text-xs mt-4 w-full justify-center">Check If You Qualify</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ── TESTIMONIALS ── */}
      <section className="py-16 section-light reveal">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14">
            {[['₹47 Cr+','Loans disbursed'],['2,400+','Customers helped'],['4.8 ★','Average rating'],['38 hrs','Avg. disbursal time']].map(([v,l])=>(
              <div key={l} className="text-center p-5 rounded-2xl" style={{background:'#fff',border:'1px solid rgba(0,0,0,.07)'}}>
                <div className="text-3xl font-bold stat-num" style={{color:'#0D0D0D'}}>{v}</div>
                <div className="text-xs mt-1" style={{color:'#6B6459'}}>{l}</div>
              </div>
            ))}
          </div>
          <div className="text-center mb-10">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Real customers</span>
            <h2 className="text-3xl font-bold mt-2" style={{color:'#0D0D0D'}}>They came in not knowing what they&apos;d get. Here&apos;s what happened.</h2>
          </div>
          <div className="grid md:grid-cols-3 gap-5">
            {[
              {q:"I'd been rejected twice before finding FLOCRED. They told me my score was 664 and exactly which NBFC would approve me at that level. Got ₹8 lakh sanctioned in 2 days.",init:'RK',name:'Rahul K.',sub:'Personal Loan · Delhi · ₹8 Lakh'},
              {q:"Home loan at 8.55% when three other brokers quoted me 9.1%+. The EMI holiday meant I didn't pay anything for the first 4 months while we were renovating. Game changer.",init:'PS',name:'Priya S.',sub:'Home Loan · Gurgaon · ₹65 Lakh'},
              {q:'Running a textile business in Noida, needed ₹40L working capital urgently. FLOCRED calculated my Drawing Power in minutes and matched me to a bank that approved in 6 days.',init:'AM',name:'Arun M.',sub:'Working Capital · Noida · ₹40 Lakh'},
            ].map(t=>(
              <div key={t.name} className="p-6 rounded-2xl flex flex-col gap-4" style={{background:'#fff',border:'1px solid rgba(0,0,0,.07)'}}>
                <div className="flex gap-1">
                  {[...Array(5)].map((_,i)=>(
                    <svg key={i} className="w-4 h-4" style={{color:'#C9A84C'}} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <p className="text-sm leading-relaxed flex-1" style={{color:'#3D3D3D'}}>"{t.q}"</p>
                <div className="flex items-center gap-3 pt-2" style={{borderTop:'1px solid rgba(0,0,0,.06)'}}>
                  <div className="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold" style={{background:'rgba(201,168,76,.15)',color:'#C9A84C'}}>{t.init}</div>
                  <div>
                    <div className="text-xs font-semibold" style={{color:'#0D0D0D'}}>{t.name}</div>
                    <div className="text-[10px]" style={{color:'#6B6459'}}>{t.sub}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── PARTNER LOGOS ── */}
      <section className="py-10 section-dark reveal">
        <div className="max-w-7xl mx-auto px-4">
          <div className="text-center text-[11px] mb-5 tracking-wider uppercase" style={{color:'rgba(245,240,232,.2)'}}>Banks and NBFCs we work with</div>
          <div className="flex flex-wrap items-center justify-center gap-4">
            {['SBI','HDFC Bank','ICICI Bank','Axis Bank','Bajaj Finance','LIC HFL','Lendingkart','Faircent','Kotak Bank','Yes Bank'].map(b=>(
              <span key={b} className="text-xs font-medium px-4 py-2 glass rounded-lg" style={{color:'rgba(245,240,232,.4)'}}>{b}</span>
            ))}
          </div>
        </div>
      </section>

      {/* ── FAQ ── */}
      <section id="faq" className="py-16 section-light reveal">
        <div className="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="text-center mb-10">
            <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Questions?</span>
            <h2 className="text-3xl font-bold mt-2" style={{color:'#0D0D0D'}}>Things people ask us</h2>
          </div>
          <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify({
            '@context':'https://schema.org','@type':'FAQPage',
            mainEntity:[
              {q:"Do you give loans directly?",a:"No — we're not a bank. We work with 50+ banks and NBFCs and help you figure out which one will approve you, at what amount and rate. The loan comes from the bank; we remove the guesswork from finding the right one."},
              {q:"Will checking my eligibility here hurt my CIBIL score?",a:"No. What we do is a soft check — it doesn't show up on your credit history and won't drop your score. Only when you formally apply with a bank (a hard inquiry) does it get recorded."},
              {q:"How much does my CIBIL score actually matter?",a:"A lot. Banks use your score (300–900) to decide if they'll lend at all, and how much interest they'll charge. Above 750 and you get the best rates. Below 650 and most banks will reject you outright."},
              {q:"How fast can I actually get the money?",a:"Personal loans with our fast-track partners disburse in 24–72 hours once documents are submitted. Home loans and business loans take 7–15 working days."},
            ].map(({q,a})=>({'@type':'Question',name:q,acceptedAnswer:{'@type':'Answer',text:a}}))
          }) }}/>
          <div className="space-y-2">
            {[
              {q:"Do you give loans directly?",a:"No — we're not a bank. We work with 50+ banks and NBFCs and help you figure out which one will approve you, at what amount and rate. The loan comes from the bank; we remove the guesswork from finding the right one."},
              {q:"How much does my CIBIL score actually matter?",a:"A lot. Banks use your score (300–900) to decide if they'll lend at all, and how much interest they'll charge. Above 750 and you get the best rates. Below 650 and most banks will reject you outright. We pull your score directly from TransUnion CIBIL and show you exactly where you stand."},
              {q:"My CIBIL score is bad. Is there any hope?",a:"Yes, but don't rush. Some NBFCs lend at scores as low as 550–600, but the interest rate will be painful. Honestly? If you have 3–6 months, use our CIBIL Boost program first (free with Pro). Getting your score above 700 before you apply will save you lakhs over the loan term."},
              {q:"Can I use a CIBIL report I already have?",a:"Yes. Upload your existing CIBIL PDF and we'll read your score, existing loans, and repayment history to calculate eligibility. If the report is over 30 days old, we ask a few quick questions to estimate where your score is today."},
              {q:"Which plan is right for me?",a:"If you're checking your own score once — Basic at ₹299 is all you need. If you're a loan agent or comparing options across multiple loans, Pro at ₹1,299 gives you 8 checks, both CIBIL and Experian reports, and CIBIL Boost. Enterprise is for HR teams and large DSA networks running 50+ checks a month."},
              {q:"Will checking my eligibility here hurt my CIBIL score?",a:"No. What we do is a soft check — it doesn't show up on your credit history and won't drop your score. Only when you formally apply with a bank (a hard inquiry) does it get recorded. This is exactly why you should check here first."},
              {q:"How fast can I actually get the money?",a:"Personal loans with our fast-track partners disburse in 24–72 hours once documents are submitted. Home loans and business loans take 7–15 working days — there's more verification involved, but we stay on it for you the whole way through."},
              {q:"Is my data safe with you?",a:"Yes. 256-bit SSL encryption, full compliance with RBI digital lending guidelines and DPDPA 2023. Your data is only shared with the specific bank you choose to apply with — and only with your consent. We don't sell data. PAN numbers are masked in our systems."},
            ].map((faq,i)=>(
              <div key={i} className="rounded-xl overflow-hidden" style={{background:'#fff',border:'1px solid rgba(0,0,0,.07)'}}>
                <button className="w-full px-5 py-4 text-left flex items-center justify-between text-sm font-medium transition-all" style={{color:'#0D0D0D'}} onClick={()=>setFaqOpen(faqOpen===i?null:i)}>
                  <span>{faq.q}</span>
                  <svg className="w-4 h-4 faq-icon flex-shrink-0 ml-3" style={{color:'#6B6459',transform:faqOpen===i?'rotate(180deg)':'rotate(0deg)',transition:'transform .2s'}} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7"/></svg>
                </button>
                {faqOpen===i&&<div className="faq-answer px-5 pb-4 text-xs leading-relaxed" style={{color:'#6B6459'}}>{faq.a}</div>}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── CONTACT ── */}
      <section id="contact" className="py-16 section-dark reveal">
        <div className="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid md:grid-cols-2 gap-8">
            <div>
              <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Talk to us</span>
              <h2 className="text-3xl font-bold mt-2 mb-4" style={{color:'#F5F0E8'}}>
                Tell us what you need. We&apos;ll call back in 30 minutes.
                {teamOnline&&<span style={{display:'inline-flex',alignItems:'center',gap:6,fontSize:11,fontWeight:500,color:'rgba(245,240,232,.4)',marginLeft:8,verticalAlign:'middle'}}>
                  <span style={{width:7,height:7,borderRadius:'50%',background:'#22c55e',display:'inline-block',animation:'pulse-glow 2s infinite'}}/>Team online now
                </span>}
              </h2>
              <p className="text-sm mb-6 leading-relaxed" style={{color:'rgba(245,240,232,.4)'}}>No automated calls. No script. A real person who has seen thousands of loan cases and can tell you exactly what your options are.</p>
              <div className="space-y-4 text-sm">
                {[
                  {href:'tel:+919319369315',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>,label:'+91-9319369315'},
                  {href:'mailto:support@flocred.com',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>,label:'support@flocred.com'},
                  {href:'',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>,label:'Delhi & Mumbai, India'},
                ].map(item=>(
                  <div key={item.label} className="flex items-center gap-3" style={{color:'rgba(245,240,232,.5)'}}>
                    <svg className="w-4 h-4" style={{color:'#C9A84C'}} fill="none" stroke="currentColor" viewBox="0 0 24 24">{item.icon}</svg>
                    {item.href?<a href={item.href} style={{color:'inherit'}}>{item.label}</a>:<span>{item.label}</span>}
                  </div>
                ))}
              </div>
            </div>
            <form onSubmit={handleContact} className="space-y-3">
              <input name="name" required placeholder="Full Name" className="input-dark"/>
              <input name="phone" required placeholder="Mobile Number" className="input-dark" maxLength={10}/>
              <input name="email" type="email" placeholder="Email (optional)" className="input-dark"/>
              <select name="loan_type" required className="input-dark" style={{appearance:'none'}}>
                <option value="">What do you need?</option>
                {[['personal_loan','Personal Loan'],['business_loan','Business Loan'],['home_loan','Home Loan'],['lap','Loan Against Property'],['car_loan','Car Loan'],['working_capital','Working Capital'],['cibil_check','CIBIL Score Check'],['cibil_boost','CIBIL Boost Program'],['other','Other']].map(([v,l])=><option key={v} value={v}>{l}</option>)}
              </select>
              <input name="amount" placeholder="Loan Amount Required (₹)" className="input-dark"/>
              <textarea name="message" rows={2} placeholder="Any specific requirement?" className="input-dark" style={{resize:'none'}}/>
              <button type="submit" className="btn-gold w-full py-3.5 rounded-xl text-sm font-semibold justify-center">Submit Application</button>
            </form>
          </div>
        </div>
      </section>

      {/* ── CAREERS ── */}
      <section className="py-16 reveal" style={{background:'linear-gradient(135deg,#0D0D0D 0%,#1A1206 50%,#0D0D0D 100%)'}}>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span className="text-xs font-semibold tracking-[.2em] uppercase" style={{color:'#C9A84C'}}>Work with us</span>
              <h2 className="text-3xl font-bold mt-2 mb-3" style={{color:'#F5F0E8'}}>If you can sell, you&apos;ll make <span className="gradient-text">more here than anywhere else.</span></h2>
              <p className="text-sm mb-4 leading-relaxed" style={{color:'rgba(245,240,232,.4)'}}>We pay on results. The more loans you close, the more you earn — no ceiling. Most of our executives clear their first big commission within 60 days.</p>
              <div className="grid grid-cols-2 gap-3 mb-5">
                <div className="glass-light rounded-xl p-3 text-center"><div className="text-base font-bold stat-num" style={{color:'#C9A84C'}}>Uncapped</div><div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>Commission</div></div>
                <div className="glass-light rounded-xl p-3 text-center"><div className="text-base font-bold stat-num" style={{color:'#C9A84C'}}>18 Mo</div><div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>Exec to Manager</div></div>
              </div>
              <Link href="/careers" className="btn-gold px-6 py-3 rounded-xl text-sm">
                View Open Positions
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </Link>
            </div>
            <div className="space-y-2">
              {[{n:1,bg:'#C9A84C',title:'Sales Executive',sub:'Month 0-6 | Learn products, build pipeline'},{n:2,bg:'#C9A84C',title:'Sr. Sales Executive',sub:'Month 6-12 | Key accounts, mentoring'},{n:3,bg:'#B8922F',title:'Team Lead',sub:'Month 12-18 | Lead team of 5-8'},{n:4,bg:'#9A7A24',title:'Sales Manager',sub:'Month 18+ | Own a region',textLight:true}].map(r=>(
                <div key={r.n} className="glass-light rounded-xl p-4 flex items-center gap-3">
                  <div className="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0" style={{background:r.bg,color:r.textLight?'#F5F0E8':'#0D0D0D'}}>{r.n}</div>
                  <div>
                    <div className="text-sm font-medium" style={{color:'#F5F0E8'}}>{r.title}</div>
                    <div className="text-[10px]" style={{color:'rgba(245,240,232,.3)'}}>{r.sub}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* ── FOOTER ── */}
      <Footer/>

      {/* ── MOBILE STICKY CTA ── */}
      <div id="mobile-sticky-cta" className="lg:hidden fixed bottom-0 left-0 right-0 z-50 px-4 py-3 flex items-center gap-3 translate-y-full opacity-0 transition-all duration-300" style={{background:'rgba(13,13,13,.95)',backdropFilter:'blur(20px)',borderTop:'1px solid rgba(201,168,76,.15)'}}>
        <a href="#eligibility" className="btn-gold flex-1 py-3 rounded-xl text-sm justify-center">Know my loan limit — free</a>
        <a href="https://wa.me/919319369315?text=Hi%2C+I+want+to+check+my+loan+eligibility" target="_blank" rel="noopener noreferrer" className="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style={{background:'#25D366'}}>
          <svg viewBox="0 0 24 24" fill="white" className="w-6 h-6"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
      </div>
    </>
  );
}
