            <p className="text-sm mt-2" style={{color:'#6B6459'}}>We show you which bank gives you the best rate for your profile — not just the lowest advertised rate.</p>
          </div>
          <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
            {([
              {type:'personal_loan',name:'Personal Loan',rate:'10.49%',max:'Rs 50 Lakh',href:'/personal-loan',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>},
              {type:'business_loan',name:'Business Loan',rate:'10.75%',max:'Rs 5 Cr',href:'/business-loan',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>},
              {type:'home_loan',name:'Home Loan',rate:'8.4%',max:'Rs 10 Cr',href:'/home-loan',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>},
              {type:'lap',name:'Loan Against Property',rate:'9.25%',max:'Up to 70% LTV',href:'/loan-against-property',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>},
              {type:'car_loan',name:'Car Loan',rate:'8.65%',max:'Up to 90% on-road',href:'/car-loan',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>},
              {type:'working_capital',name:'Working Capital',rate:'DP-based',max:'OD/CC facility',href:'/working-capital',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 10V3L4 14h7v7l9-11h-7z"/>},
              {type:'overdraft',name:'Overdraft',rate:'From 10%',max:'OD facility',href:'/working-capital',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>},
              {type:'micro_loan',name:'Micro Loan',rate:'From 20%',max:'Small ticket',href:'/personal-loan',icon:<path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1"/>},
            ] as const).map(p=>(
